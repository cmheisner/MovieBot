# Discord Bot Token (required)
DISCORD_TOKEN=your_bot_token_here

# Discord Guild ID (required) - right-click server > Copy Server ID
GUILD_ID=123456789012345678

# Channel IDs (required) - right-click channel > Copy Channel ID
STASH_CHANNEL_ID=123456789012345678
GENERAL_CHANNEL_ID=123456789012345678
SCHEDULE_CHANNEL_ID=123456789012345678

# OMDB API Key (optional but recommended) - get one free at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_key_here

# Dev Mode (optional) - restricts all commands and posts to the bot-testing channel
# DEV_MODE=true
# BOT_TESTING_CHANNEL_ID=123456789012345678

# Database path (optional, defaults to data/moviebot.db)
# DB_PATH=data/moviebot.db

# Storage backend (optional, defaults to "sqlite")
# Set to "sheets" to use Google Sheets as the database.
# STORAGE_BACKEND=sqlite

# Google Sheets (required when STORAGE_BACKEND=sheets)
# GOOGLE_SHEETS_ID=                        # Spreadsheet ID from the URL
# GOOGLE_SERVICE_ACCOUNT_PATH=credentials.json  # Local dev: path to service account JSON key file
# GOOGLE_SERVICE_ACCOUNT_JSON=             # Cloud deploy: paste the full JSON key content here

# Plex integration (optional) - shows which scheduled movies are available on your Plex server
# PLEX_URL=http://localhost:32400
# PLEX_TOKEN=your_plex_token_here
# PLEX_LIBRARY_SECTION_ID=1               # Library section ID for movies (default: 1)

# Staff role (optional) - role ID that gates Staff-only commands like /poll create.
# Defaults to the Movie Nights server's Staff role.
# STAFF_ROLE_ID=1451058938094031020
